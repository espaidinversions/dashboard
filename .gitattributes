# Normalize all text files to LF in the repository (silences CRLF/LF warnings on Windows)
* text=auto eol=lf

# Explicit LF for common source/text types
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Treat binaries as binary (never convert line endings)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
